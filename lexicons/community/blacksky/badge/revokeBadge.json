{
  "lexicon": 1,
  "id": "community.blacksky.badge.revokeBadge",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Revoke a badge from an actor. Admin only.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["actor", "badge"],
          "properties": {
            "actor": { "type": "string", "format": "did" },
            "badge": { "type": "string", "maxLength": 64 }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["found"],
          "properties": {
            "found": { "type": "boolean" }
          }
        }
      }
    }
  }
}
