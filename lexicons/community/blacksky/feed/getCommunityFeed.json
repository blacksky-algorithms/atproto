{
  "lexicon": 1,
  "id": "community.blacksky.feed.getCommunityFeed",
  "defs": {
    "main": {
      "type": "query",
      "description": "Get community posts for a given actor. Only returns results if the requester is a Blacksky community member.",
      "parameters": {
        "type": "params",
        "required": ["actor"],
        "properties": {
          "actor": {
            "type": "string",
            "format": "at-identifier",
            "description": "DID or handle of the actor whose community posts to fetch."
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "default": 50,
            "description": "Number of posts to return."
          },
          "cursor": {
            "type": "string",
            "description": "Pagination cursor."
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["feed"],
          "properties": {
            "cursor": {
              "type": "string"
            },
            "feed": {
              "type": "array",
              "items": { "type": "ref", "ref": "app.bsky.feed.defs#feedViewPost" }
            }
          }
        }
      },
      "errors": [
        {
          "name": "MembershipRequired",
          "description": "The requester is not a Blacksky community member."
        }
      ]
    }
  }
}
