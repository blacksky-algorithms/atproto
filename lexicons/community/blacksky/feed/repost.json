{
  "lexicon": 1,
  "id": "community.blacksky.feed.repost",
  "defs": {
    "main": {
      "description": "Record representing a repost of a Blacksky community post. Visible only to community members.",
      "type": "record",
      "key": "tid",
      "record": {
        "type": "object",
        "required": ["subject", "createdAt"],
        "properties": {
          "subject": { "type": "ref", "ref": "com.atproto.repo.strongRef" },
          "createdAt": { "type": "string", "format": "datetime" }
        }
      }
    }
  }
}
